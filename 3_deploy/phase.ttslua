-- 3_deploy/phase.ttslua
function deploy_phase()
    return {
        DEPLOY_SPAWN = {
            title = "SCHIERAMENTO",
            desc  = "Fai spawnare le tue unità sul tavolo",
            before = "before_deploy_spawn",
            after  = "after_deploy_spawn",
            allowedActions = { ACTION.ARMY1_CLICK, ACTION.ARMY2_CLICK },
            render = "2BtnClick",
            enforceOwnership = true,
            inputMode = "OWNER",
            buttons = {
                BTN_ARMY1 = { action="ARMY1_CLICK", label="Spawn Army 1", textColor="White", color="Red",   callback="deploy_btn_army1" },
                BTN_ARMY2 = { action="ARMY2_CLICK", label="Spawn Army 2", textColor="White", color="Green", callback="deploy_btn_army2" },
            },
            transitions = {
                { to="DEPLOY_POSITION", conditions={ COND.BOTH_PLAYERS_SELECTED } }
            }
        },
        DEPLOY_POSITION = {
            title = "SCHIERAMENTO",
            desc  = "Posiziona le tue unità, poi conferma",
            before = "before_deploy_position",
            after  = "after_deploy_position",
            allowedActions = { ACTION.ARMY1_CLICK, ACTION.ARMY2_CLICK },
            render = "2BtnClick",
            enforceOwnership = true,
            inputMode = "OWNER",
            buttons = {
                BTN_ARMY1 = { action="ARMY1_CLICK", label="Confermo Army 1", textColor="White", color="Red",   callback="deploy_position_btn_army1" },
                BTN_ARMY2 = { action="ARMY2_CLICK", label="Confermo Army 2", textColor="White", color="Green", callback="deploy_position_btn_army2" },
            },
            transitions = {
                { to="CHARGE", conditions={ COND.BOTH_PLAYERS_SELECTED } }
            }
        }
    }
end
