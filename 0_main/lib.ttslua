function main_aggiornaSchedeUnita() end
-- ============================================================
-- FUNZIONE: restart()
-- ============================================================
function main_restart()

    initPhases()

    ENGINE = ENGINE or {}
    ENGINE.handlers = ENGINE.handlers or {}
    ENGINE.conditions = ENGINE.conditions or {}

    ENGINE.phase = "SITTING"
    ENGINE.turn = 1
 
    colorArmy1 = COLOR.NOARMY
    colorArmy2 = COLOR.NOARMY
     
    DICE_CONTEST = {
        rolledNumberArmy1 = nil,
        rolledNumberArmy2 = nil,
        winner = nil,
        initiative = nil
    }
    
    TURN = {
        phase = "SITTING",
        activeArmy = nil,
        firstArmy = nil,
        completed = {
            Army1 = false,
            Army2 = false
        }
    }

    UI.setAttribute("iconWinnerArmy1", "active", "false")
    UI.setAttribute("iconWinnerArmy2", "active", "false")

    UI.setAttribute("iconMoveArmy1", "active", "false")
    UI.setAttribute("iconMoveArmy2", "active", "false")

    -- Rimuovi elementi terreno spawnati
    for _, obj in ipairs(getAllObjects()) do
        if obj.hasTag and (obj.hasTag("Hill") or obj.hasTag("Field") or obj.hasTag("Wood")) then
            obj.destruct()
        end
    end

    main_initUI()
    main_resetPlayers()
    restoreDiceUiState()
    main_updateCenterPanel()
    
    callHandler("deployment_resetRuntimeOnly")
    callHandler("deployment_clearSpawnedModels")  -- esterni: deploy module

    linea_field = false
    linee_deploy = false
    linee_spawn = true
    main_aggiornaLinee()

    fadeOut("RESTART", nil)
end
-- ============================================================
-- FUNZIONE: getArmySlotByColor()
-- ============================================================
function main_ArmySlotByColor(color)
    if color == COLOR.ARMY1 then return "Army1" end
    if color == COLOR.ARMY2 then return "Army2" end
    return nil
end
-- ============================================================
-- FUNZIONE: getColorByArmySlot()
-- ============================================================
function main_ColorByArmySlot(armySlot)
    if armySlot == "Army1" then return COLOR.ARMY1 end
    if armySlot == "Army2" then return COLOR.ARMY2 end
    return nil
end
-- ============================================================
-- FUNZIONE: ief_getSelectedObjects(player)
-- ============================================================
function main_SelectedObjects(player)
    if player then
        local selected = Player[player.color].getSelectedObjects()
        if selected and #selected > 0 then return selected end
        return {}
    end

    for _, p in ipairs(main_SeatedPlayers()) do
        local selected = Player[p.color].getSelectedObjects()
        if selected and #selected > 0 then return selected end
    end
    return {}
end
-- ============================================================
-- FUNZIONE: getSeatedPlayers()
-- ============================================================
function main_SeatedPlayers()
    local result = {}
    for _, p in ipairs(Player.getPlayers()) do
        if p and p.seated and (p.color == COLOR.ARMY1 or p.color == COLOR.ARMY2) then
            table.insert(result, p)
        end
    end
    return result
end
-- ============================================================
-- FUNZIONE: resetPlayers()
-- ============================================================
function main_resetPlayers()
    for _, p in ipairs(Player.getPlayers()) do
        if p then p.changeColor(COLOR.NOARMY) end
    end
end
-- ============================================================
-- FUNZIONE: goToPhase(phaseName)
-- Transizione manuale a una fase (bypass condizioni)
-- ============================================================
function main_goToPhase(phaseName)
    if not ENGINE or not ENGINE.phases then return end
    if not ENGINE.phases[phaseName] then
        print("[GOTO] Phase not found: " .. phaseName)
        return
    end
    local oldPhase = ENGINE.phase
    engine_exitPhase(oldPhase)
    ENGINE.phase = phaseName
    engine_resetState()
    engine_enterPhase(phaseName, oldPhase)
    main_updateCenterPanel()
end
-- ============================================================
-- FUNZIONE: resetTurnForPhase()
-- ============================================================
function main_resetTurnForPhase()
    if DEBUG then print("resetTurnForPhase") end
    if not DICE_CONTEST or not DICE_CONTEST.initiative then return end

    local army = main_ArmySlotByColor(DICE_CONTEST.initiative.color)
    TURN.phase          = ENGINE.phase
    TURN.firstArmy      = army
    TURN.activeArmy     = army
    TURN.completed.Army1 = false
    TURN.completed.Army2 = false

    print("[IEF] resetTurnForPhase: phase=" .. tostring(TURN.phase) .. " firstArmy=" .. tostring(TURN.firstArmy) .. " activeArmy=" .. tostring(TURN.activeArmy))
end
--=============================================================
--FUNZIONE: getArmyByButton()
--=============================================================
function main_getArmyByButton(id)
    for k,v in pairs(ARMY) do
        if v.button == id then
            return k
        end
    end
    return nil
end
--=============================================================
--FUNZIONE: getArmyByColor()
--=============================================================
function main_getArmyByColor(player)

    for k,v in pairs(ARMY) do
        if v.color == player.color then
            return k
        end
    end
    return nil
end
-- ============================================================
-- FUNZIONE: dice_check()
-- ============================================================
function main_dice_check()

   if not DICE_CONTEST.rolledNumberArmy1 or not DICE_CONTEST.rolledNumberArmy2 then return end

    if DICE_CONTEST.rolledNumberArmy1 == DICE_CONTEST.rolledNumberArmy2 then
        DICE_CONTEST.rolledNumberArmy1 = nil
        DICE_CONTEST.rolledNumberArmy2 = nil
        DICE_CONTEST.winner = nil
        return
    end

    if DICE_CONTEST.rolledNumberArmy1 > DICE_CONTEST.rolledNumberArmy2 then
        DICE_CONTEST.winner = 1
    else
        DICE_CONTEST.winner = 2
    end   
    
    print("Winner is Army: " .. tostring(ARMY[DICE_CONTEST.winner].name))
end

-- ============================================================
-- FUNZIONE: advanceTurnAfterClick()
-- ============================================================
function main_advanceTurnAfterClick(slot)

    print("[ADV] slot=" .. tostring(slot) .. " activeArmy=" .. tostring(TURN and TURN.activeArmy))
    
    if slot == BUTTONS.BTN_ARMY1 then
        TURN.completed.Army1 = true
    end

    if slot == BUTTONS.BTN_ARMY2 then
        TURN.completed.Army2 = true
    end

    if TURN.activeArmy == "Army1" then
        if TURN.completed.Army2 then
            TURN.activeArmy = nil
        else
            TURN.activeArmy = "Army2"
        end
        return
    end

    if TURN.activeArmy == "Army2" then
        if TURN.completed.Army1 then
            TURN.activeArmy = nil
        else
            TURN.activeArmy = "Army1"
        end
        return
    end
end
-- ============================================================
-- FUNZIONE: canUseButton()
-- ============================================================
function main_canUseButton(slot, player, value, id, button, phase)

    local mode = phase and phase.inputMode or "FREE"

    -- ========================================================
    -- FREE: tutti possono cliccare
    -- ========================================================
    if mode == "FREE" then
        return true
    end

    -- ========================================================
    -- OWNER: solo il player del bottone
    -- ========================================================
    if mode == "OWNER" then

        if slot == BUTTONS.BTN_ARMY1 then
            if not player or player.color ~= COLOR.ARMY1 then
                fadeOut("Not your button", player)
                return false
            end
        end

        if slot == BUTTONS.BTN_ARMY2 then
            if not player or player.color ~= COLOR.ARMY2 then
                fadeOut("Not your button", player)
                return false
            end
        end

        return true
    end

    -- ========================================================
    -- INITIATIVE: gestione turno con TURN
    -- ========================================================
    if mode == "INITIATIVE" then

        local activeColor = main_ColorByArmySlot(TURN.activeArmy)

        -- se esiste un turno attivo, solo lui può cliccare
        if activeColor then
            if not player or player.color ~= activeColor then
                fadeOut("Wait for your opponent", player)
                return false
            end
        end
        return true
    end

    return true
end
-- ============================================================
-- FUNZIONE: prettyPrintTable()
-- ============================================================
function main_prettyPrintTable(t, indent)
    indent = indent or 0
    if type(t) ~= "table" then
        print(tostring(t))
        return
    end
    for k, v in pairs(t) do
        local prefix = string.rep("  ", indent) .. tostring(k) .. ": "
        if type(v) == "table" then
            print(prefix)
            main_prettyPrintTable(v, indent + 1)
        else
            print(prefix .. tostring(v))
        end
    end
end
-- ============================================================
-- FUNZIONE: initUI()
-- ============================================================
function main_initUI()
    callHandler("buildUI")
end
-- rulesetInit() definita in rulesetInit.ttslua — rimossa da lib per evitare sovrascrittura
-- ============================================================
-- FUNZIONE: lionheart_findUnit(slot, tipo, unita_num)
-- Trova un'unità in DEPLOYMENT.scanned
-- ============================================================
function main_findUnit(slot, tipo, unita_num)
    local esercito = DEPLOYMENT.scanned and DEPLOYMENT.scanned[slot]
    if not esercito then return nil end

    for _, u in ipairs(esercito) do
        if u.tipo == tipo and u.unita_num == unita_num then
            return u
        end
    end
    return nil
end
-- ============================================================
-- FUNZIONE: lionheart_infoUnita()
-- ============================================================
function main_infoUnita(player, value, id, buttonConfig)

    local selected = main_getSelectedObjects(player)
    if not selected or #selected < 1 then
        warningToColor(("Seleziona un'unità"):upper(), player)
        return false
    end

    local obj = selected[1]

    -- Verifica che l'unità appartenga all'esercito del player
    local playerSlot = main_getArmyByColor(player)
    if playerSlot == nil then return false end

    local armyTag = "Army" .. tostring(playerSlot)

    if not obj.hasTag(armyTag) then
        printToColor("[INFO] Not your unit", player.color, {r=1,g=0.3,b=0.3})
        return false
    end

    main_mostraPopupUnita(obj, player)
    return true
end
-- ============================================================
-- FUNZIONE: lionheart_getSelectedObjects()
-- ============================================================
function main_getSelectedObjects(player)

    if player then
        local selected = Player[player.color].getSelectedObjects()
        if selected and #selected > 0 then return selected end
        return {}
    end

    -- fallback senza player (comportamento precedente)
    for _, p in ipairs(main_SeatedPlayers()) do
        local selected = Player[p.color].getSelectedObjects()
        if selected and #selected > 0 then return selected end
    end
    return {}
end
