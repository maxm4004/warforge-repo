-- ============================================================
-- FUNZIONE: lionheart_applyFormation()
-- ============================================================
function main_applyFormation(mode, player)

    local selected = main_getSelectedObjects(player)
    if selected == nil or #selected < 2 then
        warningToColor(("Seleziona almeno 2 basi"):upper(), {r=1,g=0.6,b=0})
        return false
    end

    local leader = selected[1]
    local right = leader.getTransformRight()
    local forward = leader.getTransformForward()

    local leaderBounds = leader.getBounds()
    local horizontalSpacing = leaderBounds.size.x
    local verticalSpacing   = leaderBounds.size.z

    for i = 2, #selected do
        local obj = selected[i]
        local index = i - 1
        local pos = nil

        if mode == "lineLeft" then
            pos = leader.getPosition() - right * (horizontalSpacing * index)
        elseif mode == "lineRight" then
            pos = leader.getPosition() + right * (horizontalSpacing * index)
        elseif mode == "columnUp" then
            pos = leader.getPosition() + forward * (verticalSpacing * index)
        elseif mode == "columnDown" then
            pos = leader.getPosition() - forward * (verticalSpacing * index)
        elseif mode == "skirmish" then
            pos = leader.getPosition() + right * (horizontalSpacing * 2 * index)
        end

        if pos ~= nil then
            obj.setPosition(pos)
            obj.setRotation(leader.getRotation())
        end
    end

    return true
end
-- ============================================================
-- FUNZIONE: aggiornaPopupUnita()
-- ============================================================
function main_aggiornaPopupUnita(slot, tipo, unita_num)
    local esercito = DEPLOYMENT.scanned and DEPLOYMENT.scanned[slot]
    if not esercito then return end

    -- Se passati tipo e unita_num aggiorna solo quell'unità
    -- altrimenti aggiorna la prima trovata
    local unita = nil
    if tipo and unita_num then
        unita = main_findUnit(slot, tipo, unita_num)
    else
        unita = esercito[1]
    end

    if not unita then return end

    local p      = "unit_popup_" .. slot
    local fpb    = (IEF_DATA.unitTypes and IEF_DATA.unitTypes[unita.tipo] or {}).figures_per_base or 1
    local fig_att  = main_figureTotaliUnita(unita)
    local fig_max  = (unita.basi_max or #unita.basi) * fpb
    local basi_p   = main_basiPresentiUnita(unita)
    local basi_max = unita.basi_max or #unita.basi
    local perc     = fig_max > 0 and (fig_att / fig_max) or 0

    local salute
    if perc == 1.0    then salute = "Healthy"
    elseif perc > 0.5 then salute = "Weakened"
    elseif perc > 0   then salute = "Critical"
    else                   salute = "Destroyed" end

    UI.setAttribute(p .. "_basi",   "text", "Bases:  " .. basi_p  .. " / " .. basi_max)
    UI.setAttribute(p .. "_figure", "text", "Figs:   " .. fig_att .. " / " .. fig_max)
    UI.setAttribute(p .. "_salute", "text", "Status: " .. salute)

    print("[POPUP] fig_att=" .. tostring(fig_att) .. " fig_max=" .. tostring(fig_max))
    for _, base in ipairs(unita.basi) do
        print("[POPUP] base=" .. tostring(base.nickname) .. " wounds=" .. tostring(wounds_data and wounds_data[base.nickname] or 0))
    end
end
-- ============================================================
-- FUNZIONE: mostraPopupUnita()
-- ============================================================
function main_mostraPopupUnita(obj, player)

    if obj == nil then return end
    local slot = nil
    if obj.hasTag("Army1") then slot = 1 end
    if obj.hasTag("Army2") then slot = 2 end
    if slot == nil then return end

    local nickname = obj.getName()
    local baseInfo = deployment_parseNickname(nickname)
    if not baseInfo then return end

    local unita = nil
    local esercito = DEPLOYMENT.scanned[slot]

    if not esercito or #esercito == 0 then
        callHandler("deployment_scanTable")
        esercito = DEPLOYMENT.scanned[slot]
    end

    if esercito then
        for _, u in ipairs(esercito) do
            if u.tipo == baseInfo.unitType and u.unita_num == baseInfo.unitNumber then
                unita = u
                break
            end
        end
    end
    if not unita then return end

    local p      = "unit_popup_" .. slot
    local tipo   = unita.tipo
    local arma   = unita.arma
    local rules  = IEF_DATA.unitTypes and IEF_DATA.unitTypes[tipo]

    local fpb    = (rules or {}).figures_per_base or 1
    local fig_att  = main_figureTotaliUnita(unita)
    local fig_max  = (unita.basi_max or #unita.basi) * fpb
    local basi_p   = main_basiPresentiUnita(unita)
    local basi_max = unita.basi_max or #unita.basi
    local perc     = fig_max > 0 and (fig_att / fig_max) or 0
    
    local salute
    if perc == 1.0   then salute = "Healthy"
    elseif perc > 0.5 then salute = "Weakened"
    elseif perc > 0   then salute = "Critical"
    else                   salute = "Destroyed" end

            local n1 = (DEPLOYMENT and DEPLOYMENT.urls and DEPLOYMENT.urls.army1 and DEPLOYMENT.urls.army1.nome or "Army 1")
            local n2 = (DEPLOYMENT and DEPLOYMENT.urls and DEPLOYMENT.urls.army1 and DEPLOYMENT.urls.army2.nome or "Army 2")

    local army_name = slot == 1 and n1 or n2
    local val_str   = (unita.valore == "S" or unita.valore == 1)  and "Superior" or
                      (unita.valore == "I" or unita.valore == -1) and "Inferior"  or "Normal"
    local unit_name = rules and (rules.name or rules.nome_display) or tipo
    local army_tag  = "Army" .. tostring(slot)

    -- HEADER
    UI.setAttribute(p, "image", "carta_icon")
    UI.setAttribute(p .. "_icon",     "image", army_tag .. "_" .. tipo)
    UI.setAttribute(p .. "_title",    "text",  unit_name:upper())
    UI.setAttribute(p .. "_subtitle", "text",  tipo .. "  ·  " .. army_name .. "  ·  " .. val_str)
    UI.setAttribute(p .. "_basi",     "text",  "Bases:  " .. basi_p  .. " / " .. basi_max)
    UI.setAttribute(p .. "_figure",   "text",  "Figs:   " .. fig_att .. " / " .. fig_max)
    UI.setAttribute(p .. "_salute",   "text",  "Status: " .. salute)
    if not arma then 
        UI.setAttribute(p .. "_weapon", "active", "false")
    else 
        UI.setAttribute(p .. "_weapon", "active", "true")
    end


    -- MOVIMENTO IEF: move_inches (campo singolo in pollici)
    local mov_val = rules and rules.move_inches and tostring(rules.move_inches) .. "\"" or "—"
    UI.setAttribute(p .. "_mov_open",  "text", mov_val)
    for _, id in ipairs({"wood","rough","ford","pivot"}) do
        UI.setAttribute(p .. "_mov_" .. id, "text", "—")
    end

    -- MELEE IEF: soglia fissa 5+ per tutti
    for _, id in ipairs({"ai","ui","sk","ac","uc","skc"}) do
        UI.setAttribute(p .. "_mel_" .. id, "text", "5+")
    end

    -- SHOOTING
    local armi_list = unita.armi or (arma and {arma}) or {}
    local w_ief = nil
    for _, a in ipairs(armi_list) do
        local w = IEF_DATA.weapons and IEF_DATA.weapons[a]
        if w and w.range_inches then w_ief = w; w_ief._key = a; break end
    end

   if w_ief then
        UI.setAttribute(p .. "_shoot_label", "text", "SHOOTING")
        UI.setAttribute(p .. "_weapon", "text", "Weapon: " .. (w_ief.name or w_ief._key) .. "    Range: " .. tostring(w_ief.range_inches) .. "\"")
        UI.setAttribute(p .. "_sho_ai",  "text", mth.AI  .. (tonumber(mth.AI)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_sho_ui",  "text", mth.UI  .. (tonumber(mth.UI)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_sho_sk",  "text", mth.SK  .. (tonumber(mth.SK)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_sho_ac",  "text", mth.AC  .. (tonumber(mth.AC)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_sho_uc",  "text", mth.UC  .. (tonumber(mth.UC)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_sho_skc", "text", mth.SKC .. (tonumber(mth.SKC) == 6 and "" or "+"))
    else
        UI.setAttribute(p .. "_shoot_label", "text", "SHOOTING")
        for _, id in ipairs({"ai","ui","sk","ac","uc","skc"}) do
            UI.setAttribute(p .. "_sho_" .. id, "text", "—")
        end
    end

    -- SPECIAL RULES
    if rules and rules.special and #rules.special > 0 then
        local txt = ""
        for _, s in ipairs(rules.special) do
            txt = txt .. s .. "\n"
        end
        UI.setAttribute(p .. "_special", "text", txt:gsub("\n$", ""))
    else
        UI.setAttribute(p .. "_special", "text", "—")
    end

    UI.setAttribute(p, "active",     "true")
    UI.setAttribute(p, "visibility", player.color)
end
-- ============================================================
-- FUNZIONE: lionheart_basiPresentiUnita(unita)
-- ============================================================
function main_basiPresentiUnita(unita)
    local count = 0
    for _, base in ipairs(unita.basi) do
        local obj = getObjectFromGUID(base.guid)
        if obj then count = count + 1 end
    end
    return count
end
-- ============================================================
-- FUNZIONE: lionheart_figureTotaliUnita(unita)
-- ============================================================
function main_figureTotaliUnita(unita)
    local fpb    = (IEF_DATA.unitTypes and IEF_DATA.unitTypes[unita.tipo] or {}).figures_per_base or 0
    local figure = 0
    for _, base in ipairs(unita.basi) do
        local wounds = wounds_data and wounds_data[base.nickname] or 0
        figure = figure + math.max(0, fpb - wounds)
    end
    return figure
end
-- ============================================================
-- FUNZIONE: aggiornaSchedeUnita() — compatibilità
-- ============================================================
function main_aggiornaSchedeUnita()
end

-- ============================================================
-- FUNZIONE: ief_data_load()
-- Carica i 7 JSON base in parallelo, poi chiama ief_data_onLoaded()
-- Le armies e i scenari vengono caricati on-demand.
-- ============================================================
function main_data_load()

    files = {
        { key = "unitTypes",    file = "unit_types.json",      wrap = "unit_types"    },
        { key = "morale",       file = "morale.json",          wrap = nil             },
        { key = "weapons",      file = "weapons.json",         wrap = nil             },
        { key = "capabilities", file = "capabilities.json",    wrap = nil             },
        { key = "terrain",      file = "terrain.json",         wrap = nil             },
        { key = "movement",     file = "movement.json",        wrap = nil             },
        { key = "melee",        file = "melee_modifiers.json", wrap = nil             }
    }

    local loaded = 0
    local total  = #files
    local errors = 0

    for _, f in ipairs(files) do
        local url  = IEF_JSON_BASE_URL .. f.file
        local fkey = f.key
        local wrap = f.wrap

        WebRequest.get(url, function(request)
            if request.is_error then
                printToAll("[IEF_DATA] Errore: " .. fkey .. " — " .. tostring(request.error), {r=1,g=0.3,b=0.3})
                errors = errors + 1
                loaded = loaded + 1
            else
                local ok, decoded = pcall(JSON.decode, request.text)
                if not ok or not decoded then
                    printToAll("[IEF_DATA] JSON decode fallito: " .. fkey, {r=1,g=0.3,b=0.3})
                    errors = errors + 1
                else
                    -- Alcuni JSON hanno un wrapper root (es. unit_types.json → .unit_types)
                    if wrap and decoded[wrap] then
                        IEF_DATA[fkey] = decoded[wrap]
                    else
                        IEF_DATA[fkey] = decoded
                    end
                end
                loaded = loaded + 1
            end

            if loaded == total then
                main_data_onLoaded(errors)
            end
        end)
    end
end
-- ============================================================
-- FUNZIONE: ief_data_onLoaded(errors)
-- Chiamata quando tutti i JSON base sono stati processati.
-- ============================================================
function main_data_onLoaded(errors)
    if errors and errors > 0 then
        printToAll("[IEF_DATA] Caricamento completato con " .. errors .. " errori.", {r=1,g=0.6,b=0})
    else
        local nUnit = 0
        for _ in pairs(IEF_DATA.unitTypes or {}) do nUnit = nUnit + 1 end
        printToAll("[IEF_DATA] Dati Json caricati - " .. nUnit .. " file", {r=0.4,g=0.9,b=0.4})
    end


    callHandler("ief_data_ready")
end
-- ============================================================
-- FUNZIONE: ief_loadButtonBar()
-- ============================================================
function main_loadButtonBar(callback)
    WebRequest.get(IEF_URL_BUTTONBAR, function(request)
        if request.is_error then
            printToAll("[IEF] Errore download buttonbar.json", {r=1,g=0.3,b=0.3})
            if callback then callback(false) end
            return
        end
        local ok = callHandler("engine_buttonBarLoadJson", request.text)
        if callback then callback(ok) end
    end)
end
-- ============================================================
-- FUNZIONE: ief_loadArmy(nome, callback)
-- Carica on-demand l'esercito richiesto (cache in IEF_DATA.armies).
-- ============================================================
function main_loadArmy(nome, callback)
    if IEF_DATA.armies[nome] then
        if callback then callback(IEF_DATA.armies[nome]) end
        return
    end

    WebRequest.get(IEF_JSON_ARMIES_URL .. nome .. ".json", function(request)
        if request.is_error then
            printToAll("[IEF_DATA] Errore caricamento esercito: " .. nome, {r=1,g=0.3,b=0.3})
            if callback then callback(nil) end
            return
        end
        local ok, decoded = pcall(JSON.decode, request.text)
        if not ok or not decoded then
            printToAll("[IEF_DATA] JSON decode fallito: armies/" .. nome, {r=1,g=0.3,b=0.3})
            if callback then callback(nil) end
            return
        end
        IEF_DATA.armies[nome] = decoded
        if callback then callback(decoded) end
    end)
end
-- ============================================================
-- FUNZIONE: ief_loadScenario(nome, callback)
-- Carica on-demand lo scenario richiesto (cache in IEF_DATA.scenari).
-- ============================================================
function main_loadScenario(nome, callback)
    if IEF_DATA.scenari[nome] then
        if callback then callback(IEF_DATA.scenari[nome]) end
        return
    end

    WebRequest.get(IEF_JSON_SCENARI_URL .. nome .. ".json", function(request)
        if request.is_error then
            printToAll("[IEF_DATA] Errore caricamento scenario: " .. nome, {r=1,g=0.3,b=0.3})
            if callback then callback(nil) end
            return
        end
        local ok, decoded = pcall(JSON.decode, request.text)
        if not ok or not decoded then
            printToAll("[IEF_DATA] JSON decode fallito: scenari/" .. nome, {r=1,g=0.3,b=0.3})
            if callback then callback(nil) end
            return
        end
        IEF_DATA.scenari[nome] = decoded
        if callback then callback(decoded) end
    end)
end
-- ============================================================
-- FUNZIONE: ief_data_reset()
-- ============================================================
function main_data_reset()
    IEF_DATA.unitTypes    = {}
    IEF_DATA.morale       = {}
    IEF_DATA.weapons      = {}
    IEF_DATA.capabilities = {}
    IEF_DATA.terrain      = {}
    IEF_DATA.movement     = {}
    IEF_DATA.melee        = {}
    IEF_DATA.armies       = {}
    IEF_DATA.scenari      = {}
end
-- ============================================================
-- API PUBBLICA — funzioni di accesso read-only
-- Tutte fanno guard su nil e stampano un errore chiaro.
-- ex:ief_getUnitType("KN") → { base_width_cm=4, base_depth_cm=3, ... }
-- ============================================================
function main_getUnitType(tipo)
    if not IEF_DATA.unitTypes then
        print("[IEF_DATA] unitTypes non caricato"); return nil
    end
    local r = IEF_DATA.unitTypes[tipo]
    if not r then print("[IEF_DATA] Tipo unità non trovato: " .. tostring(tipo)) end
    return r
end

-- ============================================================
-- FUNZIONE: ief_data_reset()
-- ============================================================
function main_getMorale(livello)
    local levels = IEF_DATA.morale and IEF_DATA.morale.morale_levels
    if not levels then
        print("[IEF_DATA] morale_levels non caricato"); return nil
    end
    local r = levels[livello]
    if not r then print("[IEF_DATA] Livello morale non trovato: " .. tostring(livello)) end
    return r
end
-- ============================================================
-- FUNZIONE: ief_data_reset()
-- ============================================================
function main_getMoraleModifier(chiave)
    local mods = IEF_DATA.morale and IEF_DATA.morale.morale_modifiers
    if not mods then
        print("[IEF_DATA] morale_modifiers non caricato"); return nil
    end
    local r = mods[chiave]
    if r == nil then print("[IEF_DATA] Modificatore morale non trovato: " .. tostring(chiave)) end
    return r
end
-- ============================================================
-- FUNZIONE: ief_data_reset()
-- ============================================================
function main_getMoraleEffect(esito, situazione)
    local effects = IEF_DATA.morale and IEF_DATA.morale.morale_effects
    if not effects then
        print("[IEF_DATA] morale_effects non caricato"); return nil
    end
    local e = effects[esito]
    if not e then
        print("[IEF_DATA] Esito morale non trovato: " .. tostring(esito)); return nil
    end
    local r = e[situazione]
    if not r then print("[IEF_DATA] Situazione morale non trovata: " .. tostring(situazione)) end
    return r
end

-- ============================================================
-- FUNZIONE: ief_data_reset()
-- ============================================================
function main_getWeapon(arma)
    local weapons = IEF_DATA.weapons and IEF_DATA.weapons.weapons
    if not weapons then
        print("[IEF_DATA] weapons non caricato"); return nil
    end
    local r = weapons[arma]
    if not r then print("[IEF_DATA] Arma non trovata: " .. tostring(arma)) end
    return r
end
-- ============================================================
-- FUNZIONE: ief_data_reset()
-- ============================================================
function main_getWeaponRange(arma)
    local w = main_getWeapon(arma)
    return w and w.range_inches or nil
end
-- ============================================================
-- FUNZIONE: main_getCapability(capacita)
-- ============================================================                                     
function main_getCapability(capacita)
    local caps = IEF_DATA.capabilities and IEF_DATA.capabilities.capabilities
    if not caps then
        print("[IEF_DATA] capabilities non caricato"); return nil
    end
    local r = caps[capacita]
    if not r then print("[IEF_DATA] Capacità non trovata: " .. tostring(capacita)) end
    return r
end
-- ============================================================
-- FUNZIONE: main_getTerrainEffect(tipoTerreno, tipoUnita)
-- ============================================================    
function main_getTerrainEffect(tipoTerreno, tipoUnita)
    local terrain = IEF_DATA.terrain and IEF_DATA.terrain.terrain_types
    if not terrain then
        print("[IEF_DATA] terrain non caricato"); return nil
    end
    local t = terrain[tipoTerreno]
    if not t then
        print("[IEF_DATA] Terreno non trovato: " .. tostring(tipoTerreno)); return nil
    end
    local r = t.effects and t.effects[tipoUnita]
    if not r then print("[IEF_DATA] Effetto terreno non trovato per: " .. tostring(tipoUnita)) end
    return r
end
-- ============================================================
-- FUNZIONE: main_canManeuver(manovra, tipoUnita)
-- ============================================================   
function main_canManeuver(manovra, tipoUnita)
    local maneuvers = IEF_DATA.movement and IEF_DATA.movement.maneuvers
    if not maneuvers then
        print("[IEF_DATA] movement non caricato"); return nil
    end
    local m = maneuvers[manovra]
    if not m then
        print("[IEF_DATA] Manovra non trovata: " .. tostring(manovra)); return nil
    end
    return m[tipoUnita] == true
end
-- ============================================================
-- FUNZIONE: main_getMeleeThreshold()
-- ============================================================   
function main_getMeleeThreshold()
    local melee = IEF_DATA.melee and IEF_DATA.melee.melee
    if not melee then
        print("[IEF_DATA] melee non caricato"); return nil
    end
    return melee.hit_threshold
end
-- ============================================================
-- FUNZIONE: main_getMeleeModifiers(isFirstTurn)
-- ============================================================   
function main_getMeleeModifiers(isFirstTurn)
    local melee = IEF_DATA.melee and IEF_DATA.melee.melee
    if not melee then
        print("[IEF_DATA] melee non caricato"); return {}
    end
    if isFirstTurn then
        return melee.first_turn_modifiers or {}
    else
        return melee.subsequent_turn_modifiers or {}
    end
end
-- ============================================================
-- FUNZIONE: main_getMeleeDiceRule(chiave)  
-- ============================================================   
function main_getMeleeDiceRule(chiave)
    local melee = IEF_DATA.melee and IEF_DATA.melee.melee
    if not melee or not melee.dice_rules then
        print("[IEF_DATA] melee dice_rules non caricato"); return nil
    end
    local r = melee.dice_rules[chiave]
    if not r then print("[IEF_DATA] Regola dadi mischia non trovata: " .. tostring(chiave)) end
    return r
end
-- ============================================================
-- FUNZIONE: main_getArmy(nome)
-- ============================================================   
function main_getArmy(nome)
    local r = IEF_DATA.armies[nome]
    if not r then
        print("[IEF_DATA] Esercito non in cache: " .. tostring(nome) .. " — usare ief_loadArmy()")
    end
    return r
end
-- ============================================================
-- FUNZIONE: main_getArmyUnit(nomeEsercito, nomeUnita)
-- ============================================================   
function main_getArmyUnit(nomeEsercito, nomeUnita)
    local army = main_getArmy(nomeEsercito)
    if not army or not army.units then return nil end
    for _, u in ipairs(army.units) do
        if u.name == nomeUnita then return u end
    end
    print("[IEF_DATA] Unità non trovata: " .. tostring(nomeUnita) .. " in " .. tostring(nomeEsercito))
    return nil
end
-- ============================================================
-- FUNZIONE: main_getScenario(nome)
-- ============================================================   
function main_getScenario(nome)
    local r = IEF_DATA.scenari[nome]
    if not r then
        print("[IEF_DATA] Scenario non in cache: " .. tostring(nome) .. " — usare ief_loadScenario()")
    end
    return r
end
-- ============================================================
-- FUNZIONE: main_initUI()
-- ============================================================   
function main_initUI()
    if DEBUG then print("initUI") end
    callHandler("buildUI")
end




