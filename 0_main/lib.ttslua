-- ============================================================
-- FUNZIONE: updateCenterPanel()
-- ============================================================
function main_updateCenterPanel()
    
    if not ENGINE or not ENGINE.phases then return end
    local phase = ENGINE.phases[ENGINE.phase]
    if not phase then return end

    -- Renderer PRIMA — attiva i panel corretti
    local renderer = RENDERERS and RENDERERS[phase.render]
    if renderer then
        renderer(phase)
    else
        printToAll("[IEF] Renderer non trovato: " .. tostring(phase.render), "Red")
    end

    -- Fase e descrizione
    pcall(function()
        UI.setAttribute("versione", "text", VERSION)
        UI.setAttribute("textTurno", "text", "Turno: " .. tostring(ENGINE.turn or 1))
        UI.setAttribute("textFase", "text", (phase.title or ENGINE.phase))
        UI.setAttribute("textDesc", "text", phase.desc or "")
    end)

    -- Nomi e colori eserciti 
    pcall(function() 
        local n1 = (DEPLOYMENT and DEPLOYMENT.urls and DEPLOYMENT.urls.army1 and DEPLOYMENT.urls.army1.nome or "Army 1")
        local n2 = (DEPLOYMENT and DEPLOYMENT.urls and DEPLOYMENT.urls.army1 and DEPLOYMENT.urls.army2.nome or "Army 2")

        UI.setAttribute("army1", "text",  n1)
        UI.setAttribute("army2", "text",  n2)
        UI.setAttribute("army1", "color", colorArmy1 or COLOR.NOARMY)
        UI.setAttribute("army2", "color", colorArmy2 or COLOR.NOARMY)
    end)

    -- Label e colore bottoni DOPO panel già attivo
    pcall(function()
        for slot, button in pairs(phase.buttons or {}) do
            UI.setAttribute(slot, "color",     button.color     or "Grey")
            UI.setAttribute(slot, "text",      button.label     or slot)
            UI.setAttribute(slot, "textColor", button.textColor or "White")
        end
    end)

    -- Stato bottoni
    pcall(function()
        if ENGINE.phase == PHASE.SITTING then
            if colorArmy1 ~= COLOR.NOARMY then
                UI.setAttribute(BUTTONS.BTN_ARMY1, "color", COLOR.NOARMY)
            end
            if colorArmy2 ~= COLOR.NOARMY then
                UI.setAttribute(BUTTONS.BTN_ARMY2, "color", COLOR.NOARMY)
            end
        elseif phase.inputMode == "INITIATIVE" then

            print("[IEF] updateCenterPanel: INITIATIVE mode fase " .. ENGINE.phase .. " activeArmy=" .. tostring(TURN and TURN.activeArmy))
            UI.setAttribute(BUTTONS.BTN_ARMY1, "interactable", "true")
            UI.setAttribute(BUTTONS.BTN_ARMY2, "interactable", "true")
            UI.setAttribute(BUTTONS.BTN_ARMY1, "textColor", "White")
            UI.setAttribute(BUTTONS.BTN_ARMY2, "textColor", "White")
            UI.setAttribute(BUTTONS.BTN_ARMY1, "color", colorArmy1 or COLOR.NOARMY)
            UI.setAttribute(BUTTONS.BTN_ARMY2, "color", colorArmy2 or COLOR.NOARMY)

            if TURN and TURN.activeArmy == "Army1" then
                print("[IEF] updateCenterPanel: Army1 active")
                
                UI.setAttribute(BUTTONS.BTN_ARMY1, "interactable", "true")
                UI.setAttribute(BUTTONS.BTN_ARMY1, "textColor", "White")

                UI.setAttribute(BUTTONS.BTN_ARMY2, "interactable", "false")
                UI.setAttribute(BUTTONS.BTN_ARMY2, "color", COLOR.NOARMY)
                UI.setAttribute(BUTTONS.BTN_ARMY2, "textColor", "Black")
            elseif TURN and TURN.activeArmy == "Army2" then
                print("[IEF] updateCenterPanel: Army2 active")

                UI.setAttribute(BUTTONS.BTN_ARMY2, "interactable", "true")
                UI.setAttribute(BUTTONS.BTN_ARMY2, "textColor", "White")

                UI.setAttribute(BUTTONS.BTN_ARMY1, "interactable", "false")
                UI.setAttribute(BUTTONS.BTN_ARMY1, "color", COLOR.NOARMY)
                UI.setAttribute(BUTTONS.BTN_ARMY1, "textColor", "Black")
            end

else
            -- reset interactable per OWNER mode
            UI.setAttribute(BUTTONS.BTN_ARMY1, "interactable", "true")
            UI.setAttribute(BUTTONS.BTN_ARMY2, "interactable", "true")
            UI.setAttribute(BUTTONS.BTN_ARMY1, "textColor", "White")
            UI.setAttribute(BUTTONS.BTN_ARMY2, "textColor", "White")

            if TURN and TURN.completed then
                if TURN.completed.Army1 then
                    UI.setAttribute(BUTTONS.BTN_ARMY1, "color", COLOR.NOARMY)
                end
                if TURN.completed.Army2 then
                    UI.setAttribute(BUTTONS.BTN_ARMY2, "color", COLOR.NOARMY)
                end
            end
        end
    end)
end
-- ============================================================
-- FUNZIONE: aggiornaLinee()
-- ============================================================
function main_aggiornaLinee()

      
    local linee = {}

    local Y_LINEE    = 1.22
    local LX         = 66.70
    local LZ         = 44.35
    local CM_TO_TTS  = LX / 90.0   -- 66.70 / 90 = 0.741
    local DEPLOY_TTS = 30.48 * CM_TO_TTS   -- 12 pollici in TTS = 22.59
    local LAT_TTS    = 15.24 * CM_TO_TTS   -- 6 pollici in TTS = 11.29

    if linea_field then
        table.insert(linee, { 
            points={{x=-LX,y=Y_LINEE,z=0},{x=LX,y=Y_LINEE,z=0}}, color={r=0.8,g=0.8,b=0.8}, thickness=0.3})
    end

    if linee_deploy then
        local y = Y_LINEE
        table.insert(linee, { points={{x=-LX,y=y,z=-(LZ-DEPLOY_TTS)},{x=LX,y=y,z=-(LZ-DEPLOY_TTS)}}, color={r=0.9,g=0.2,b=0.2}, thickness=0.3 })
        table.insert(linee, { points={{x=-LX,y=y,z= (LZ-DEPLOY_TTS)},{x=LX,y=y,z= (LZ-DEPLOY_TTS)}}, color={r=0.2,g=0.8,b=0.2}, thickness=0.3 })
    end

    if linee_spawn then

        local y   = Y_LINEE
        local profondita = 22
        local gap = 5  -- unità TTS di distanza dal bordo tavolo

            -- Rettangolo Army1 (rosso)
            table.insert(linee, { points={
                {x=-LX, y=y, z=-(LZ+gap)},
                {x= LX, y=y, z=-(LZ+gap)},
                {x= LX, y=y, z=-(LZ+gap+profondita)},
                {x=-LX, y=y, z=-(LZ+gap+profondita)},
                {x=-LX, y=y, z=-(LZ+gap)}
            }, color={r=1,g=0,b=0}, thickness=0.3 })

            -- Rettangolo Army2 (verde)
            table.insert(linee, { points={
                {x=-LX, y=y, z= LZ+gap},
                {x= LX, y=y, z= LZ+gap},
                {x= LX, y=y, z= LZ+gap+profondita},
                {x=-LX, y=y, z= LZ+gap+profondita},
                {x=-LX, y=y, z= LZ+gap}
            }, color={r=0,g=1,b=0}, thickness=0.3 })
    end

            -- if linee_settori then
        --     local cols=6; local rows=5
        --     local sx=(VERDE_LX*2)/cols; local sz=(VERDE_LZ*2)/rows; local y=3.5
        --     for c=0,cols do local x=-VERDE_LX+c*sx; table.insert(linee,{points={{x,y,-VERDE_LZ},{x,y,VERDE_LZ}},color={r=0.2,g=0.8,b=0.8},thickness=0.1}) end
        --     for r=0,rows do local z=-VERDE_LZ+r*sz; table.insert(linee,{points={{-VERDE_LX,y,z},{VERDE_LX,y,z}},color={r=0.2,g=0.8,b=0.8},thickness=0.1}) end
        -- end

    if ENGINE_MEASURE and ENGINE_MEASURE.activeLine then
        table.insert(linee, ENGINE_MEASURE.activeLine)
    end

    if IEF_SHOOTING and IEF_SHOOTING.activeLines then
        for _, l in ipairs(IEF_SHOOTING.activeLines) do
            table.insert(linee, l)
        end
    end

    Global.setVectorLines(linee)
end
